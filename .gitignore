# Ignore Visual Studio temporary files, build results, and user-specific files

# Build results
bin/
obj/
[Bb]uild/
[Bb]uilds/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Mono Auto Generated Files
mono_crash.*

# Visual Studio working folder
.vs/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# StyleCop
StyleCopReport.xml

# Others
*.dbmdl
*.bak
*.cache
*.log
*.pdb
*.tmp

# Rider & VS Code (optional, if not using them)
.idea/
.vscode/

# Publish folder
publish/

# NuGet Packages
*.nupkg
packages/
*.snupkg

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
ictvisitorsfrontendsystem/.env*

# Dependencies
node_modules/
ictvisitorsfrontendsystem/node_modules/
ictvisitorsfrontendsystem/.next/
ictvisitorsfrontendsystem/.pnpm-store/
ictvisitorsfrontendsystem/pnpm-lock.yaml

# Build outputs
ictvisitorsfrontendsystem/out/
ictvisitorsfrontendsystem/dist/
ICTVisitorsManagementSystem/**/bin/
ICTVisitorsManagementSystem/**/obj/
ICTVisitorsManagementSystem/**/Debug/
ICTVisitorsManagementSystem/**/Release/

# IDE
*.swp
*.swo
*~
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# Misc
*.zip
*.tar.gz
*.rar

# OS
Thumbs.db

# .NET
ICTVisitorsManagementSystem/**/appsettings.Development.json
ICTVisitorsManagementSystem/**/appsettings.Production.json
*.cache
